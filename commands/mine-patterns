#!/usr/bin/env python3
"""Command wrapper for the pattern miner.

Runs the conversation history mining tool using the project's Python.
Equivalent to: python scripts/mine_patterns.py "$@"

See scripts/mine_patterns.py --help for full usage.
"""

import os
import sys
from pathlib import Path

# Resolve project root from this script's location
PROJECT_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(PROJECT_ROOT / "scripts"))

from mine_patterns import main

if __name__ == "__main__":
    main()
else:
    # When executed as a command (not imported), also run main
    main()
