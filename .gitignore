# SLC / Conda — installed environments (platform-specific subdirs)
envs/*/
*.lock.cache/

# Explicitly track spec files and lockfiles in envs/
!envs/*.yml
!envs/*.lock

# Python
__pycache__/
*.py[cod]

# Claude Code
.claude/cache/
.claude/logs/

# Project team state (optional - keep or ignore)
.ao_project_team/*/specification/*.md
# But always keep STATUS.md tracked for continuity

# OS / Editor
.DS_Store
.vscode/
.idea/

# Data (customize per project)
data/raw/
data/processed/
*.csv
*.parquet
