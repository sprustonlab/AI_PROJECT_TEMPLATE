#!/usr/bin/env python3
"""Launch claudechic TUI."""

import os
import subprocess
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent
os.chdir(PROJECT_ROOT)

# Ensure claudechic submodule is initialized
claudechic_dir = PROJECT_ROOT / "submodules" / "claudechic"
if not (claudechic_dir / "pyproject.toml").exists():
    print("⚠️  claudechic submodule not initialized")
    print("Initializing submodule...")
    subprocess.run(
        ["git", "submodule", "update", "--init", "submodules/claudechic"],
        cwd=PROJECT_ROOT,
        check=True,
    )
    print("✔ Submodule initialized")

# Run claudechic via pixi
sys.exit(
    subprocess.run(
        ["pixi", "run", "-e", "claudechic", "python", "-m", "claudechic"] + sys.argv[1:],
        cwd=PROJECT_ROOT,
    ).returncode
)
