# SLC / Conda
envs/SLCenv/
envs/*/
*.lock.cache/
__pycache__/
*.py[cod]

# Claude Code
.claude/cache/
.claude/logs/
.claude/hits.jsonl

# Claudechic session state
.chicsessions/

# Guardrail runtime artifacts (generated at runtime, not tracked)
.claude/guardrails/acks/
.claude/guardrails/sessions/
.claude/guardrails/session_names.json
.claude/guardrails/hits.jsonl

# Hints runtime state
.claude/hints_state.json

# Phase context (written at runtime by workflow engine)
.claude/phase_context.md

# Test artifacts
.test_runs/

# Project team runtime state (tracked on develop, blocked from main via pre-commit hook)

# submodules/claudechic/ is a git submodule — tracked by .gitmodules

# NFS temp files
.nfs*
commands/.nfs*

# OS / Editor
.DS_Store
.vscode/
.idea/

# Data (customize per project)
data/raw/
data/processed/
*.csv
*.parquet
