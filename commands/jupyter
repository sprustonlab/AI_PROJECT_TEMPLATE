#!/bin/bash
# Launch Jupyter Lab locally

# Get the directory where this script is located
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Ensure jupyter environment is installed and activated
source "$SCRIPT_DIR/require_env" jupyter || exit 1

# Launch Jupyter Lab
echo "🚀 Starting Jupyter Lab..."
echo "   Press Ctrl+C to stop the server"
echo ""

# Find the conda env's jupyter, skipping this wrapper script
JUPYTER_EXE=$(command -v jupyter 2>/dev/null | grep -v "commands/jupyter" | head -1)
if [ -z "$JUPYTER_EXE" ]; then
    echo "❌ Error: jupyter executable not found in conda environment"
    exit 1
fi

"$JUPYTER_EXE" lab "$@"
