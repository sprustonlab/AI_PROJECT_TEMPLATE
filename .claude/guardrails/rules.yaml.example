# rules.yaml.example — Synthetic rules for framework integration tests.
# These rules exercise every mechanism in generate_hooks.py + role_guard.py.
# NOT project rules — purely for testing the guardrail framework itself.
#
# Usage (test_framework.py copies this as rules.yaml into a temp dir,
# runs generate_hooks.py, then tests the generated hooks as subprocesses):
#   pytest .claude/guardrails/test_framework.py -v

catalog_version: "fw-test-1"
ack_ttl_seconds: 120

rules:

  # ── FW01: regex_match on Bash (deny, universal) ───────────────────────────
  # Mechanism: basic regex_match + deny enforcement on command field
  - id: FW01
    name: fw-regex-match-deny
    trigger: PreToolUse/Bash
    enforcement: deny
    detect:
      type: regex_match
      pattern: '\bdangerous_cmd\b'
    message: "[FW01] dangerous_cmd is denied."

  # ── FW02: regex_miss on Bash (warn, universal) ───────────────────────────
  # Mechanism: regex_miss — fires when pattern does NOT match
  - id: FW02
    name: fw-regex-miss-warn
    trigger: PreToolUse/Bash
    enforcement: warn
    detect:
      type: regex_miss
      pattern: '\bsafe_prefix\b'
    message: "[FW02] Command must contain safe_prefix."

  # ── FW03: field extraction on MCP trigger ─────────────────────────────────
  # Mechanism: MCP trigger + field: extraction + regex_match
  - id: FW03
    name: fw-mcp-field-match
    trigger: mcp__fw__test_tool
    enforcement: deny
    detect:
      type: regex_match
      field: color
      pattern: '\bred\b'
    message: "[FW03] red color is denied."

  # ── FW04: regex_miss on MCP trigger ───────────────────────────────────────
  # Mechanism: MCP trigger + field: extraction + regex_miss
  - id: FW04
    name: fw-mcp-field-miss
    trigger: mcp__fw__test_tool
    enforcement: warn
    detect:
      type: regex_miss
      field: shape
      pattern: '^(circle|square)$'
    message: "[FW04] shape must be circle or square."

  # ── FW05: regex flags (IGNORECASE) ────────────────────────────────────────
  # Mechanism: flags list on regex_match
  - id: FW05
    name: fw-flags-ignorecase
    trigger: PreToolUse/Bash
    enforcement: deny
    detect:
      type: regex_match
      pattern: '\bFLAGTEST\b'
      flags: [IGNORECASE]
    message: "[FW05] FLAGTEST matched (case-insensitive)."

  # ── FW06: multi-pattern (OR list) ─────────────────────────────────────────
  # Mechanism: pattern as a list — any match fires the rule
  - id: FW06
    name: fw-multi-pattern
    trigger: PreToolUse/Bash
    enforcement: deny
    detect:
      type: regex_match
      pattern:
        - '\balpha_bad\b'
        - '\bbeta_bad\b'
    message: "[FW06] alpha_bad or beta_bad matched."

  # ── FW07: exclude_if_matches ──────────────────────────────────────────────
  # Mechanism: exclude_if_matches suppresses rule when exclusion regex matches
  - id: FW07
    name: fw-exclude-if
    trigger: PreToolUse/Bash
    enforcement: deny
    detect:
      type: regex_match
      pattern: '\bguarded_action\b'
    exclude_if_matches: '\bbypass_ok\b'
    message: "[FW07] guarded_action is denied (unless bypass_ok present)."

  # ── FW08: exclude_contexts (python_dash_c) ────────────────────────────────
  # Mechanism: context stripping before pattern match
  - id: FW08
    name: fw-exclude-context
    trigger: PreToolUse/Bash
    enforcement: deny
    detect:
      type: regex_match
      pattern: '\bcontext_word\b'
      exclude_contexts: [python_dash_c, python_heredoc]
    message: "[FW08] context_word matched outside stripped contexts."

  # ── FW09: block:[Coordinator] role gate ───────────────────────────────────
  # Mechanism: regex_match + block:[Coordinator] — only fires for Coordinator
  - id: FW09
    name: fw-block-coordinator
    trigger: PreToolUse/Bash
    enforcement: deny
    detect:
      type: regex_match
      pattern: '\bcoord_restricted\b'
    block: [Coordinator]
    message: "[FW09] Coordinator cannot run coord_restricted."

  # ── FW10: block:[Subagent] role gate ──────────────────────────────────────
  # Mechanism: regex_match + block:[Subagent] — only fires for sub-agents
  - id: FW10
    name: fw-block-subagent
    trigger: PreToolUse/Bash
    enforcement: warn
    detect:
      type: regex_match
      pattern: '\bsubagent_restricted\b'
    block: [Subagent]
    message: "[FW10] Subagents cannot run subagent_restricted."

  # ── FW11: allow:[SpecialRole] — allowlist gate ────────────────────────────
  # Mechanism: allow list — only SpecialRole is exempt; everyone else gets enforcement
  - id: FW11
    name: fw-allow-special
    trigger: PreToolUse/Bash
    enforcement: warn
    detect:
      type: regex_match
      pattern: '\bprivileged_cmd\b'
    allow: [SpecialRole]
    message: "[FW11] Only SpecialRole may run privileged_cmd."

  # ── FW12: Write/Edit trigger (deny, universal) ───────────────────────────
  # Mechanism: Write/Edit trigger with regex_match on file_path (target)
  - id: FW12
    name: fw-write-deny
    trigger: [PreToolUse/Write, PreToolUse/Edit]
    enforcement: deny
    detect:
      type: regex_match
      pattern: '\.secret$'
      target: file_path
    message: "[FW12] Cannot write .secret files."

  # ── FW13: Write/Edit warn with ack token flow ─────────────────────────────
  # Mechanism: Write warn → ack token via role_guard.py CLI
  - id: FW13
    name: fw-write-warn-ack
    trigger: [PreToolUse/Write, PreToolUse/Edit]
    enforcement: warn
    detect:
      type: regex_match
      pattern: '\.draft$'
      target: file_path
    message: "[FW13] Writing .draft files requires acknowledgement."

  # ── FW14: Write/Edit exclude_if_matches ───────────────────────────────────
  # Mechanism: Write trigger with exclude_if_matches on file_path
  - id: FW14
    name: fw-write-exclude
    trigger: [PreToolUse/Write, PreToolUse/Edit]
    enforcement: deny
    detect:
      type: regex_match
      pattern: '_generated\.'
      target: file_path
    exclude_if_matches: '^safe_dir/'
    message: "[FW14] Cannot write _generated files outside safe_dir/."

  # ── FW15: Read trigger (deny) ─────────────────────────────────────────────
  # Mechanism: Read trigger with target: file_path
  - id: FW15
    name: fw-read-deny
    trigger: PreToolUse/Read
    enforcement: deny
    detect:
      type: regex_match
      pattern: '\.classified$'
      flags: [IGNORECASE]
      target: file_path
    message: "[FW15] Cannot read .classified files."

  # ── FW16: Glob trigger with path_is_root condition ────────────────────────
  # Mechanism: conditions.path_is_root special handling
  - id: FW16
    name: fw-glob-root-warn
    trigger: PreToolUse/Glob
    enforcement: warn
    detect:
      type: regex_match
      pattern: '\*\*'
      target: pattern
      conditions:
        path_is_root: true
    message: "[FW16] Avoid ** glob from repository root."

  # ── FW17: Bash ack prefix suppression ─────────────────────────────────────
  # Mechanism: warn-level match suppressible via # ack:<RULE_ID> prefix
  - id: FW17
    name: fw-ack-prefix
    trigger: PreToolUse/Bash
    enforcement: warn
    detect:
      type: regex_match
      pattern: '\bwarn_action\b'
    message: "[FW17] warn_action requires acknowledgement."

  # ── FW18: deny > warn priority ────────────────────────────────────────────
  # Mechanism: when both deny and warn match, deny takes precedence
  # This rule (deny) + FW17 (warn) can fire on the same command
  - id: FW18
    name: fw-deny-priority
    trigger: PreToolUse/Bash
    enforcement: deny
    detect:
      type: regex_match
      pattern: '\bwarn_action\b.*\bdeny_also\b'
      flags: [DOTALL]
    message: "[FW18] deny takes precedence over warn."

  # ── FW19: hits.jsonl logging ──────────────────────────────────────────────
  # Mechanism: verify that matched rules are logged to hits.jsonl
  # (Uses same FW01 mechanism — test class reads hits.jsonl after trigger)

  # ── FW20: log enforcement (exit 0, record only) ──────────────────────────
  # Mechanism: log enforcement — exits 0 but records to hits.jsonl
  - id: FW20
    name: fw-log-only
    trigger: PreToolUse/Bash
    enforcement: log
    detect:
      type: regex_match
      pattern: '\blog_this_event\b'
    block: [Agent]
    message: "[FW20] Logged event (no block)."

  # ── FW21: enabled: false (disabled rule) ──────────────────────────────────
  # Mechanism: disabled rules should not generate any hook code
  - id: FW21
    name: fw-disabled-rule
    trigger: PreToolUse/Bash
    enforcement: deny
    detect:
      type: regex_match
      pattern: '\bdisabled_pattern\b'
    message: "[FW21] This rule is disabled and should never fire."
    enabled: false

  # ── FW22: regex_miss on Bash (deny, universal) ───────────────────────────
  # Mechanism: regex_miss with deny — fires when command lacks required_token
  - id: FW22
    name: fw-regex-miss-deny
    trigger: PreToolUse/Bash
    enforcement: deny
    detect:
      type: regex_miss
      pattern: '\brequired_token\b'
    exclude_if_matches: '\bexempt_cmd\b'
    message: "[FW22] Command must contain required_token."

  # ── FW23: block:[TeamAgent] — fires for all team members ─────────────────
  # Mechanism: TeamAgent group covers Coordinator + all sub-agents in team mode
  - id: FW23
    name: fw-block-teamagent
    trigger: PreToolUse/Bash
    enforcement: warn
    detect:
      type: regex_match
      pattern: '\bteam_restricted\b'
    block: [TeamAgent]
    message: "[FW23] All team agents are warned about team_restricted."
